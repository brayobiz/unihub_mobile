rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
               getUserData(request.auth.uid).get("isAdmin", false) == true ||
               "admin" in getUserData(request.auth.uid).get("roles", [])
             );
    }

    function isIdentityVerified() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData(request.auth.uid).get("isIdentityVerified", false) == true;
    }

    function isVerified() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
               getUserData(request.auth.uid).get("isIdentityVerified", false) == true ||
               getUserData(request.auth.uid).get("isStudentVerified", false) == true ||
               getUserData(request.auth.uid).get("accountType", "student") == "business"
             );
    }

    function canManageOrganizer(orgId) {
      return isAdmin() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/organizers/$(orgId)) && (
          get(/databases/$(database)/documents/organizers/$(orgId)).data.ownerId == request.auth.uid ||
          (exists(/databases/$(database)/documents/organizers/$(orgId)/members/$(orgId + "_" + request.auth.uid)) &&
           get(/databases/$(database)/documents/organizers/$(orgId)/members/$(orgId + "_" + request.auth.uid)).data.role in ["administrator", "owner"])
        )
      );
    }

    function isMemberOfOrganizer(orgId) {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/organizers/$(orgId)) &&
         get(/databases/$(database)/documents/organizers/$(orgId)).data.ownerId == request.auth.uid) ||
        exists(/databases/$(database)/documents/organizers/$(orgId)/members/$(orgId + "_" + request.auth.uid))
      );
    }

    // --- Config & System ---
    match /config/system_settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campuses/{campusId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated(); // Needed for profile views
      allow create: if isOwner(userId) &&
                      !request.resource.data.keys().hasAny(['isAdmin', 'roles', 'isBanned', 'isIdentityVerified', 'isStudentVerified', 'isEmailVerified', 'isPhoneVerified']) &&
                      request.resource.data.get('accountType', 'student') == 'student' &&
                      (request.resource.data.get('businessSubscriptionStatus', 'none') == 'none' || request.resource.data.get('businessSubscriptionStatus', null) == null) &&
                      request.resource.data.get('trustScore', 0.0) <= 5.0;

      allow update: if isAdmin() || (
        isOwner(userId) && (
          // Case 1: Standard profile update (No protected keys)
          (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isAdmin', 'roles', 'isIdentityVerified', 'isStudentVerified', 'isEmailVerified', 'isPhoneVerified', 'isBanned', 'suspendedUntil', 'accountType', 'businessSubscriptionStatus', 'subscriptionExpiry', 'hasActiveWarning', 'warningReason', 'lastWarningAt', 'isDeleted'])) ||

          // Case 2: Spark Plan Self-Healing (Owner clears restriction AFTER expiry)
          (resource.data.get('suspendedUntil', request.time) <= request.time &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['suspendedUntil', 'isDeleted', 'updatedAt']) &&
           !request.resource.data.keys().hasAny(['suspendedUntil']) &&
           request.resource.data.get('isDeleted', false) == false
          ) ||

          // Case 3: Verified user upgrading to business account (Growth Phase)
          ((resource.data.get("isIdentityVerified", false) == true || resource.data.get("isStudentVerified", false) == true) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['accountType', 'businessName', 'businessCategory', 'tier']) &&
           request.resource.data.get("accountType", "student") == 'business'
          ) ||

          // Case 4: Self-deletion (Setting isDeleted to true)
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['isDeleted']) &&
           request.resource.data.get('isDeleted', false) == true &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt', 'updatedAt'])
          )
        )
      ) || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['averageRating', 'ratingsCount', 'trustScore', 'completedSalesCount', 'activeListingsCount'])
      );

      allow delete: if isAdmin() || isOwner(userId);

      match /notifications/{notificationId} {
        // Allow recipient, admin, or the sender (actor) to read/update for aggregation
        allow read: if isOwner(userId) || isAdmin() || (isAuthenticated() && resource.data.actorId == request.auth.uid);
        allow create: if isAuthenticated();
        allow update: if isOwner(userId) || isAdmin() || (isAuthenticated() && resource.data.actorId == request.auth.uid);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /collections/{collectionName}/listings/{listingId} {
        allow read, write, delete: if isOwner(userId) || isAdmin();
      }

      match /{collectionId}/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && (
          collectionId in ["tokens", "recently_viewed", "saved_listings", "saved_housing", "saved_searches", "recent_searches", "study_progress", "followed_organizers", "collections", "saved_events", "saved_notes"] ||
          collectionId.matches('^recently_viewed_.*') ||
          collectionId.matches('^saved_.*') ||
          collectionId.matches('^recent_searches_.*')
        );

        allow delete: if isOwner(userId);
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.reviewerId == request.auth.uid;
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.reviewerId == request.auth.uid);
      }
    }

    // --- Marketplace ---
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'savesCount', 'sharesCount', 'chatsStartedCount'])) ||
                    (isAuthenticated() && (
                      isAdmin() ||
                      (resource.data.get("sellerId", "") == request.auth.uid && (
                        // Case A: Spark Plan Self-Healing Restoration
                        (getUserData(request.auth.uid).get('suspendedUntil', request.time) <= request.time &&
                         getUserData(request.auth.uid).get('isBanned', false) == false &&
                         resource.data.status == 'userSuspended' &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'originalStatus'])
                        ) ||

                        // Case B: Basic update (No moderation/premium fields modified)
                        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isFeatured', 'isPromoted', 'isSponsored', 'featuredUntil', 'featuredPackage', 'featuredAt', 'sponsoredUntil', 'lastBoostedAt', 'boostCount', 'flagged', 'flagReason', 'flagAdminNotes', 'originalStatus', 'moderationReason', 'suspendedBy', 'suspendedAt', 'suspensionReason', 'approvedAt']) &&
                         // Security: If item was suspended by admin, owner can't manually un-suspend it
                         (resource.data.status != 'userSuspended' || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
                        ) ||

                        // Case C: Verified user using "Early Bird" free premium features
                        (isVerified() &&
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['flagged', 'flagReason', 'flagAdminNotes', 'originalStatus', 'moderationReason', 'suspendedBy', 'suspendedAt', 'suspensionReason', 'approvedAt']) &&
                         (resource.data.status != 'userSuspended' || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])) &&
                         // Basic sanity: only enforce limits if the fields are actually being changed
                         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['featuredUntil']) ||
                          request.resource.data.get('featuredUntil', request.time) <= request.time + duration.value(40, 'd')) &&
                         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['sponsoredUntil']) ||
                          request.resource.data.get('sponsoredUntil', request.time) <= request.time + duration.value(40, 'd'))
                        )
                      ))
                    ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get("sellerId", "") == request.auth.uid);
    }

    match /offers/{offerId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.get("buyerId", "") == request.auth.uid || resource.data.get("sellerId", "") == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.get("buyerId", "") == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || resource.data.get("buyerId", "") == request.auth.uid || resource.data.get("sellerId", "") == request.auth.uid);
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if true;
      allow create: if isMemberOfOrganizer(request.resource.data.organizerId) || isAdmin();

      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'sharesCount', 'savesCount', 'currentAttendeeCount'])) ||
                    (isAdmin() || (
                      canManageOrganizer(resource.data.organizerId) && (
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isFeatured', 'isPromoted']) ||
                        request.resource.data.status in ['draft', 'submitted', 'cancelled', 'archived']
                      )
                    ));

      allow delete: if isAdmin() || (
        isAuthenticated() &&
        (resource.data.get("createdBy", "") == request.auth.uid || canManageOrganizer(resource.data.organizerId)) &&
        resource.data.status == "draft"
      );
    }

    match /event_attendance/{docId} {
      allow read: if isAuthenticated() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        isAdmin() ||
        (resource != null && (
          resource.data.userId == request.auth.uid ||
          (exists(/databases/$(database)/documents/events/$(resource.data.eventId)) &&
           canManageOrganizer(get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.get("organizerId", "")))
        ))
      );
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      docId == request.auth.uid + "_" + request.resource.data.eventId &&
                      (request.resource.data.status != "going" || isIdentityVerified());
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.get("userId", "") == request.auth.uid);
    }

    match /event_categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /organizers/{organizerId} {
      allow read: if true;
      allow create: if isAuthenticated() && isIdentityVerified();

      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'sharesCount'])) ||
                    (isAdmin() || (
                      canManageOrganizer(organizerId) && (
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verificationStatus', 'trustScore']) ||
                        request.resource.data.verificationStatus in ['submitted', 'underReview', 'withdrawn']
                      )
                    ));

      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if canManageOrganizer(organizerId) ||
                      (isAuthenticated() && memberId == organizerId + "_" + request.auth.uid);
        allow update, delete: if canManageOrganizer(organizerId) || (
          isAuthenticated() && resource.data.userId == request.auth.uid
        );
      }

      match /audit_trail/{auditId} {
        allow read: if canManageOrganizer(organizerId);
        allow write: if canManageOrganizer(organizerId);
      }
    }

    // --- Housing ---
    match /housing_listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.plugId == request.auth.uid;
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'saves', 'sharesCount', 'chatCount', 'callCount'])) ||
                    (isAdmin() || (
                      isAuthenticated() &&
                      resource.data.get("plugId", "") == request.auth.uid && (
                        // Case A: Spark Plan Self-Healing Restoration
                        (getUserData(request.auth.uid).get('suspendedUntil', request.time) <= request.time &&
                         getUserData(request.auth.uid).get('isBanned', false) == false &&
                         resource.data.status == 'userSuspended' &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'originalStatus'])
                        ) ||
                        // Case B: Basic update
                        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isFeatured', 'moderatorNotes', 'flagged', 'originalStatus']) &&
                         (resource.data.status != 'userSuspended' || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
                        )
                      )
                    ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get("plugId", "") == request.auth.uid);

      match /history/{historyId} {
        allow read: if isAdmin() || (isAuthenticated() && resource.data.plugId == request.auth.uid);
        allow create: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/housing_listings/$(listingId)).data.plugId == request.auth.uid);
      }
    }

    match /roommates/{profileId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.get("userId", "") == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.get("userId", "") == request.auth.uid);
    }

    match /housing_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.reviewerId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.reviewerId == request.auth.uid);
    }

    match /housing_vacancy_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'claimedByPlugId', 'claimedByPlugName']));
      allow delete: if isAdmin();
    }

    match /housing_saved_searches/{searchId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /housing_viewing_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || resource.data.plugId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.plugId == request.auth.uid || resource.data.studentId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Notes ---
    match /notes/{noteId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'saves', 'sharesCount', 'downloadsCount'])) ||
                    (isAdmin() || (
                      isAuthenticated() &&
                      resource.data.get("authorId", "") == request.auth.uid &&
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['flagged', 'flagReason', 'flagAdminNotes'])
                    ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get("authorId", "") == request.auth.uid);
    }

    // --- Chat & Support ---
    match /conversations/{convId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource == null ||
        request.auth.uid in resource.data.get("participants", [])
      );
      allow create: if isAuthenticated() &&
                    request.auth.uid in request.resource.data.get("participants", []);
      allow update: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid in resource.data.get("participants", [])
      );

      match /messages/{msgId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/conversations/$(convId)) &&
           request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get("participants", []))
        );
        allow create: if isAuthenticated() && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/conversations/$(convId)) &&
           request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get("participants", []))
        );
      }
    }

    // --- Moderation & Admin ---
    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.get("reporterId", "") == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /housing_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /identity_verifications/{docId} {
      allow read: if isOwner(docId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(docId);
      allow update, delete: if isAdmin();
      allow delete: if isOwner(docId);
    }

    match /student_verifications/{docId} {
      allow read: if isOwner(docId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(docId);
      allow update, delete: if isAdmin();
      allow delete: if isOwner(docId);
    }

    match /verification_applications/{docId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /organizer_verification_requests/{docId} {
      allow read: if (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    match /admin_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /platform_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Monetization ---
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && (
        request.resource.data.status == 'pending' ||
        (request.resource.data.status == 'completed' && (request.resource.data.amount == 0 || request.resource.data.amount == 0.0) && isVerified())
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /subscriptions/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isOwner(userId) && isVerified());
    }

    // --- Background Tasks ---
    match /notifications_queue/{queueId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // --- Community Feed & Gigs ---
    match /feed/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'likedBy', 'sharesCount', 'viewsCount', 'commentsCount'])) ||
                    (isAuthenticated() && (
                      isAdmin() ||
                      (resource.data.get("authorId", "") == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPinned', 'status']))
                    ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get("authorId", "") == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      }
    }

    // --- Student Gigs ---
    match /gigs/{gigId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.employerId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.employerId == request.auth.uid);
    }

    match /gig_applications/{appId} {
      allow read: if isAuthenticated() && (resource.data.freelancerId == request.auth.uid || resource.data.employerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.freelancerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.employerId == request.auth.uid || resource.data.freelancerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /gig_disputes/{disputeId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.reporterId == request.auth.uid || resource.data.targetUserId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    // --- Collection Groups ---
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/saved_housing/{docId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/saved_listings/{docId} {
      allow read: if isAuthenticated();
    }
  }
}
