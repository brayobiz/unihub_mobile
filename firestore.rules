rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("isAdmin", false) == true ||
        "admin" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("roles", [])
      );
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Private sub-collections
      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
      match /recently_viewed/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /saved_searches/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /collections/{collectionId}/listings/{listingId} {
        allow read, write: if isOwner(userId);
      }
      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(userId) || isAdmin();
      }
      match /study_progress/{noteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Marketplace ---
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.get("sellerId", "") == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get("sellerId", "") == request.auth.uid);
    }

    match /offers/{offerId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.get("buyerId", "") == request.auth.uid || resource.data.get("sellerId", "") == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || resource.data.get("buyerId", "") == request.auth.uid || resource.data.get("sellerId", "") == request.auth.uid);
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.get("createdBy", "") == request.auth.uid);
    }

    match /event_attendance/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.get("userId", "") == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.get("userId", "") == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.get("userId", "") == request.auth.uid);
    }

    match /event_categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /organizers/{organizerId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.get("ownerId", "") == request.auth.uid);

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update, delete: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/organizers/$(organizerId)).data.ownerId == request.auth.uid);
      }

      match /audit_trail/{auditId} {
        allow read: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/organizers/$(organizerId)).data.ownerId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    // --- Housing ---
    match /housing_listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.get("plugId", "") == request.auth.uid);
    }

    // --- Notes ---
    match /notes/{noteId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.get("authorId", "") == request.auth.uid);
    }

    // --- Chat & Support ---
    match /conversations/{convId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid in resource.data.get("participants", []));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid in resource.data.get("participants", []));

      match /messages/{msgId} {
        allow read: if isAuthenticated() && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get("participants", []));
        allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get("participants", []));
      }
    }

    // --- Moderation & Admin ---
    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.get("reporterId", "") == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /housing_reports/{reportId} {
      allow read, write: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /identity_verifications/{docId} {
      allow read: if isOwner(docId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /student_verifications/{docId} {
      allow read: if isOwner(docId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /verification_applications/{docId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /organizer_verification_requests/{docId} {
      allow read: if (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /admin_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /platform_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Background Tasks ---
    match /notifications_queue/{queueId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // --- Community Feed (Confessions, Gigs, Discussions) ---
    match /feed/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.get("authorId", "") == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'likedBy', 'sharesCount']))
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get("authorId", "") == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
    }

    // --- Student Gigs (Applications & Disputes) ---
    match /gig_applications/{appId} {
      allow read: if isAuthenticated() && (resource.data.freelancerId == request.auth.uid || resource.data.employerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.employerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /gig_disputes/{disputeId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.reporterId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
  }
}
